#!/usr/bin/env python3
"""
stackmd_portable: build a single-file markdown "codebase pack" for LLM review.

Goals:
- one portable markdown file
- aggressively skip junk
- include a directory tree, file index, and reading guide
- use per-file modes: full, chunked, summary, skip
- keep large repos within a practical size budget

Examples:
  ./stackmd_portable.py
  ./stackmd_portable.py ../repo
  ./stackmd_portable.py ../repo -o repo_pack.md
  ./stackmd_portable.py ../repo --extensions .py,.ts,.tsx
  ./stackmd_portable.py ../repo --docs-only
  ./stackmd_portable.py ../repo --max-output-chars 1200000
  ./stackmd_portable.py ../repo --include-hidden
"""

