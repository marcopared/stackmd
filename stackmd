def get_language(path: Path) -> str:
    return LANGUAGE_MAP.get(path.suffix.lower(), path.suffix.lower().lstrip(".") or "text")


def normalize_extensions(raw: Optional[str]) -> Optional[frozenset[str]]:
    if not raw:
        return None
    values: List[str] = []
    for item in raw.split(","):
        item = item.strip().lower()
        if not item:
            continue
        values.append(item if item.startswith(".") else f".{item}")
    return frozenset(values) if values else None


def has_valid_extension(path: Path, extensions: Optional[frozenset[str]]) -> bool:
    return extensions is None or path.suffix.lower() in extensions


def load_pattern_file(root: Path, filename: str) -> List[str]:
    path = root / filename
    if not path.exists() or not path.is_file():
        return []
    patterns: List[str] = []
    try:
        for raw in path.read_text(encoding="utf-8", errors="replace").splitlines():
            line = raw.strip()
            if not line or line.startswith("#"):
                continue
            patterns.append(line)
    except OSError as exc:
        eprint(f"Warning: cannot read pattern file {path}: {exc}")
    return patterns


def match_pattern(rel_path: str, name: str, is_dir: bool, pattern: str) -> bool:
    rel_path = rel_path.replace("\\", "/")
    pattern = pattern.strip().replace("\\", "/")
    if not pattern:
        return False

    anchored = pattern.startswith("/")
    if anchored:
        pattern = pattern[1:]

    dir_only = pattern.endswith("/")
    if dir_only:
        pattern = pattern.rstrip("/")

    candidates = [rel_path]
    if not anchored:
        candidates.append(name)

    for candidate in candidates:
        if fnmatch.fnmatchcase(candidate, pattern):
            if not dir_only or is_dir:
                return True
        if dir_only and (candidate == pattern or candidate.startswith(pattern + "/")):
            return True

    if not anchored and "/" not in pattern:
        path_parts = rel_path.split("/")
        for idx in range(len(path_parts)):
            sub = "/".join(path_parts[idx:])
            if fnmatch.fnmatchcase(sub, pattern):
                if not dir_only or is_dir:
                    return True
            if dir_only and (sub == pattern or sub.startswith(pattern + "/")):
                return True

    return False


def matches_any_pattern(rel_path: str, is_dir: bool, patterns: Sequence[str]) -> bool:
    name = Path(rel_path).name
    return any(match_pattern(rel_path, name, is_dir, pattern) for pattern in patterns)


def should_skip_dir(name: str, include_hidden: bool, use_default_ignores: bool) -> bool:
    if use_default_ignores and name in SKIP_DIRS:
        return True
    if not include_hidden and name.startswith("."):
        return True
    return False


def is_binary(file_path: Path) -> bool:
    text_suffixes = {
        ".md", ".mdx", ".txt", ".rst",
        ".py", ".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs",
        ".json", ".yaml", ".yml", ".toml", ".ini", ".cfg",
        ".sh", ".bash", ".zsh",
        ".css", ".scss", ".sass", ".html", ".xml",
        ".sql", ".graphql", ".proto",
        ".go", ".java", ".c", ".cc", ".cpp", ".h", ".hpp", ".rs",
        ".env",
    }

    if file_path.suffix.lower() in text_suffixes:
        return False

    try:
        with open(file_path, "rb") as f:
            chunk = f.read(BINARY_CHECK_CHUNK_SIZE)
    except OSError:
        return True

    if not chunk:
        return False
    if b"\x00" in chunk:
        return True

    text_byte_set = set(range(32, 127)) | {9, 10, 13, 8, 12}
    nontext = sum(byte not in text_byte_set for byte in chunk)
    return (nontext / len(chunk)) > 0.30


def should_skip_file(
    path: Path,
    rel_path: str,
    include_hidden: bool,
    extensions: Optional[frozenset[str]],
    use_default_ignores: bool,
    custom_ignore_patterns: Sequence[str],
) -> Optional[Tuple[str, str]]:
    name = path.name
    suffix = path.suffix.lower()

    if not include_hidden and name.startswith("."):
        return ("default", "hidden")
    if use_default_ignores and name in SKIP_EXACT_FILES:
        return ("default", "lockfile/local env")
    if use_default_ignores and suffix in SKIP_SUFFIXES:
        return ("default", "binary or low-signal asset")
    if custom_ignore_patterns and matches_any_pattern(rel_path, False, custom_ignore_patterns):
        return ("custom", "matched ignore pattern")
    if not has_valid_extension(path, extensions):
        return ("default", "extension filtered out")
    if is_binary(path):
        return ("default", "binary")
    return None


def collect_files(
    roots: Sequence[RootConfig],
    include_hidden: bool,
    extensions: Optional[frozenset[str]],
    use_default_ignores: bool,
) -> CollectResult:
    included: List[Tuple[Path, RootConfig, str]] = []
    skipped: List[Tuple[str, str]] = []
    default_ignored_count = 0
    custom_ignored_count = 0
    binary_skipped_count = 0

    def walk(root_cfg: RootConfig, current: Path) -> None:
        nonlocal default_ignored_count, custom_ignored_count, binary_skipped_count
        try:
            entries = sorted(current.iterdir(), key=lambda p: p.name.lower())
        except OSError as exc:
            eprint(f"Warning: cannot read directory {current}: {exc}")
            return

        for entry in entries:
            try:
                is_dir = entry.is_dir()
            except OSError:
                continue

            rel = str(entry.relative_to(root_cfg.root)).replace("\\", "/")
            display_rel = rel if len(roots) == 1 else f"{root_cfg.display_name}/{rel}"

            if is_dir:
                if should_skip_dir(entry.name, include_hidden, use_default_ignores):
                    skipped.append((display_rel + "/", "skipped directory"))
                    default_ignored_count += 1
                    continue
                if root_cfg.ignore_patterns and matches_any_pattern(rel, True, root_cfg.ignore_patterns):
                    skipped.append((display_rel + "/", "matched ignore pattern"))
                    custom_ignored_count += 1
                    continue
                walk(root_cfg, entry)
                continue

            result = should_skip_file(
                entry,
                rel,
                include_hidden,
                extensions,
                use_default_ignores,
                root_cfg.ignore_patterns,
            )
            if result:
                group, reason = result
                skipped.append((display_rel, reason))
                if group == "custom":
                    custom_ignored_count += 1
                else:
                    default_ignored_count += 1
                    if reason == "binary":
                        binary_skipped_count += 1
                continue

            included.append((entry, root_cfg, display_rel))

    for root_cfg in roots:
        walk(root_cfg, root_cfg.root)

    included.sort(key=lambda item: item[2])
    skipped.sort(key=lambda x: x[0])
    return CollectResult(
        files=included,
        skipped=skipped,
        default_ignored_count=default_ignored_count,
        custom_ignored_count=custom_ignored_count,
        binary_skipped_count=binary_skipped_count,
    )


def read_file_content(path: Path) -> Optional[str]:
    try:
        return path.read_text(encoding="utf-8", errors="replace")
    except OSError as exc:
        eprint(f"Warning: cannot read file {path}: {exc}")
        return None


def remove_excess_whitespace(content: str, path: Path) -> str:
    if path.suffix.lower() in WHITESPACE_SENSITIVE_EXTENSIONS:
        return content

    lines = content.splitlines()
    cleaned: List[str] = []
    blank_run = 0
    for line in lines:
        stripped = line.rstrip()
        if stripped == "":
            blank_run += 1
            if blank_run > 1:
                continue
            cleaned.append("")
        else:
            blank_run = 0
            cleaned.append(stripped)

    result = "\n".join(cleaned).strip("\n")
    if content.endswith("\n") and result:
        result += "\n"
    return result


def summarize_role(path: Path) -> str:
    name = path.name.lower()
    parts = [p.lower() for p in path.parts]
    suffix = path.suffix.lower()

    if name in {"readme", "readme.md", "readme.mdx", "readme.txt"}:
        return "project overview and setup"
    if name in {"package.json", "pyproject.toml", "cargo.toml", "go.mod", "pom.xml"}:
        return "dependency and build configuration"
    if name in {"tsconfig.json", "turbo.json", "vite.config.ts", "next.config.js", "next.config.ts"}:
        return "build/runtime configuration"
    if name.startswith("dockerfile") or name in {"docker-compose.yml", "docker-compose.yaml"}:
        return "container/runtime configuration"
    if name.startswith(".env"):
        return "environment configuration"
    if suffix in {".md", ".mdx", ".txt"}:
        return "documentation"
    if suffix in {".json", ".yaml", ".yml", ".toml", ".ini", ".cfg"}:
        return "configuration"
    if (
        "test" in parts
        or "tests" in parts
        or name.endswith((".test.ts", ".spec.ts", ".test.js", ".spec.js", ".test.py", ".spec.py"))
    ):
        return "tests"
    if any(part in {"prisma", "migrations", "schema"} for part in parts) or name == "schema.prisma":
        return "database schema or migration"
    if any(part in {"api", "routes", "route", "controllers"} for part in parts):
        return "API surface or routing"
    if any(part in {"types", "interfaces", "models", "schemas"} for part in parts):
        return "shared types or schemas"
    if name.startswith(("index.", "main.", "app.")):
        return "entrypoint"
    return "source code"


def priority_score(path: Path, role: str) -> int:
    rp = str(path).replace("\\", "/").lower()
    name = path.name.lower()
    score = 0

    if name in {
        "readme.md",
        "readme.mdx",
        "readme.txt",
        "package.json",
        "pyproject.toml",
        "go.mod",
        "cargo.toml",
        "dockerfile",
        "schema.prisma",
    }:
        score += 100
    if role in {
        "project overview and setup",
        "dependency and build configuration",
        "entrypoint",
        "database schema or migration",
        "API surface or routing",
    }:
        score += 60
    if any(token in rp for token in ["src/main", "src/index", "/app/", "/pages/", "/routes/", "/api/", "/services/", "/core/", "/lib/"]):
        score += 35
    if role == "tests":
        score -= 20
    if "/generated/" in rp or "/gen/" in rp:
        score -= 60
    return score


def first_nonempty_lines(content: str, limit: int = 12) -> List[str]:
    out: List[str] = []
    for raw in content.splitlines():
        line = raw.strip()
        if not line:
            continue
        out.append(line[:MAX_SUMMARY_LINE_LEN])
        if len(out) >= limit:
            break
    return out


def extract_summary_points(path: Path, content: str, role: str) -> List[str]:
    import re

    suffix = path.suffix.lower()
    points: List[str] = []

    if suffix in {".md", ".mdx"}:
        for line in content.splitlines():
            match = re.match(r"^(#{1,3})\s+(.*)$", line.strip())
            if match:
                points.append(f"heading: {match.group(2).strip()[:MAX_SUMMARY_LINE_LEN]}")
            if len(points) >= MAX_SUMMARY_BULLETS:
                break
    elif suffix in {".ts", ".tsx", ".js", ".jsx", ".py", ".go", ".java", ".rs"}:
        patterns = [
            r"^(?:export\s+)?(?:async\s+)?function\s+([A-Za-z_][A-Za-z0-9_]*)",
            r"^(?:export\s+)?class\s+([A-Za-z_][A-Za-z0-9_]*)",
            r"^(?:export\s+)?(?:const|let|var)\s+([A-Za-z_][A-Za-z0-9_]*)\s*=",
            r"^def\s+([A-Za-z_][A-Za-z0-9_]*)",
            r"^class\s+([A-Za-z_][A-Za-z0-9_]*)",
        ]
        combined = re.compile("|".join(patterns), re.MULTILINE)
        for match in combined.finditer(content):
            symbol = next((group for group in match.groups() if group), None)
            if symbol:
                points.append(f"symbol: {symbol}")
            if len(points) >= MAX_SUMMARY_BULLETS:
                break
    elif suffix in {".json", ".yaml", ".yml", ".toml", ".ini", ".cfg"}:
        for line in first_nonempty_lines(content, limit=20):
            if line.startswith(("{", "}", "[", "]")):
                continue
            points.append(f"config: {line}")
            if len(points) >= MAX_SUMMARY_BULLETS:
                break

    if not points:
        for line in first_nonempty_lines(content, limit=MAX_SUMMARY_BULLETS):
            points.append(f"excerpt: {line}")

    if role:
        points.insert(0, f"role: {role}")

    return points[:MAX_SUMMARY_BULLETS]


def line_number_index(content: str) -> List[int]:
    offsets = [0]
    for line in content.splitlines(keepends=True):
        offsets.append(offsets[-1] + len(line))
    return offsets


def offset_to_line(offsets: Sequence[int], char_offset: int) -> int:
    lo, hi = 0, len(offsets) - 1
    while lo <= hi:
        mid = (lo + hi) // 2
        if offsets[mid] <= char_offset:
            lo = mid + 1
        else:
            hi = mid - 1
    return max(1, hi + 1)


def chunk_markdown(content: str) -> List[Chunk]:
    import re

    lines = content.splitlines()
    chunks: List[Chunk] = []
    current_title = "Document start"
    current_lines: List[str] = []
    current_start = 1

    def flush(end_line: int) -> None:
        nonlocal current_title, current_lines, current_start
        text = "\n".join(current_lines).strip("\n")
        if text:
            chunks.append(Chunk(current_title, current_start, end_line, text))

    for idx, line in enumerate(lines, start=1):
        if re.match(r"^#{1,3}\s+", line):
            flush(idx - 1)
            current_title = re.sub(r"^#{1,3}\s+", "", line).strip() or "Untitled section"
            current_lines = [line]
            current_start = idx
        else:
            current_lines.append(line)

    flush(len(lines))
    return chunks or [Chunk("Full file", 1, len(lines), content)]


def chunk_code(content: str) -> List[Chunk]:
    import re

    patterns = [
        r"^(?:export\s+)?(?:async\s+)?function\s+([A-Za-z_][A-Za-z0-9_]*)",
        r"^(?:export\s+)?class\s+([A-Za-z_][A-Za-z0-9_]*)",
        r"^(?:export\s+)?(?:const|let|var)\s+([A-Za-z_][A-Za-z0-9_]*)\s*=",
        r"^def\s+([A-Za-z_][A-Za-z0-9_]*)",
        r"^class\s+([A-Za-z_][A-Za-z0-9_]*)",
    ]
    regex = re.compile("|".join(patterns), re.MULTILINE)
    matches = list(regex.finditer(content))
    lines = content.splitlines()

    if not matches:
        return [Chunk("Full file", 1, len(lines), content)]

    offsets = line_number_index(content)
    chunks: List[Chunk] = []
    starts = [match.start() for match in matches]
    bounds = starts + [len(content)]

    prelude_end_line = offset_to_line(offsets, starts[0]) - 1
    if prelude_end_line >= 1:
        prelude = "\n".join(lines[:prelude_end_line]).strip("\n")
        if prelude:
            chunks.append(Chunk("Prelude / imports", 1, prelude_end_line, prelude))

    for idx, match in enumerate(matches):
        start = bounds[idx]
        end = bounds[idx + 1]
        symbol = next((group for group in match.groups() if group), f"section_{idx + 1}")
        start_line = offset_to_line(offsets, start)
        end_line = max(start_line, offset_to_line(offsets, end) - 1)
        text = content[start:end].strip("\n")
        if text:
            chunks.append(Chunk(f"Symbol `{symbol}`", start_line, end_line, text))

    return chunks or [Chunk("Full file", 1, len(lines), content)]


def choose_mode(
    path: Path,
    role: str,
    content: str,
    priority: int,
    full_cutoff: int,
    chunk_cutoff: int,
    is_minified: bool,
) -> str:
    char_count = len(content)
    line_count = len(content.splitlines())
    rp = str(path).replace("\\", "/").lower()

    if is_minified:
        return "minified"
    if "/generated/" in rp or "/gen/" in rp or rp.endswith(".min.js"):
        return "summary"
    if priority >= 100:
        return "full" if char_count <= max(full_cutoff * 2, 50000) else "chunked"
    if role in {
        "project overview and setup",
        "dependency and build configuration",
        "entrypoint",
        "database schema or migration",
        "API surface or routing",
    }:
        return "full" if char_count <= max(full_cutoff, 25000) else "chunked"
    if role == "documentation":
        return "full" if char_count <= full_cutoff else "chunked"
    if role == "tests":
        return "summary" if char_count > 4000 or line_count > 150 else "full"
    if char_count <= full_cutoff and line_count <= 250:
        return "full"
    if char_count <= chunk_cutoff and line_count <= 1200:
        return "chunked"
    return "summary"


def build_directory_tree(records: Sequence[FileRecord]) -> List[str]:
    children: Dict[str, set[str]] = {}

    for record in records:
        parts = record.relative_path.split("/")
        prefix = ""
        for idx, part in enumerate(parts):
            key = prefix
            children.setdefault(key, set()).add(part)
            prefix = f"{prefix}/{part}" if prefix else part
            if idx < len(parts) - 1:
                children.setdefault(prefix, set())

    lines: List[str] = []

    def walk(prefix: str, depth: int) -> None:
        if len(lines) >= MAX_TREE_LINES:
            return
        names = sorted(children.get(prefix, set()), key=str.lower)
        for name in names:
            path = f"{prefix}/{name}" if prefix else name
            is_dir = path in children and bool(children[path])
            lines.append(f"{'  ' * depth}- {name}{'/' if is_dir else ''}")
            if is_dir:
                walk(path, depth + 1)
                if len(lines) >= MAX_TREE_LINES:
                    return

    walk("", 0)
    if len(lines) >= MAX_TREE_LINES:
        lines.append("- ... tree truncated ...")
    return lines


def format_code_fence(content: str, language: str) -> List[str]:
    return [f"```{language}", content, "```"]


def cap_chunk_content(text: str, max_chars: int) -> str:
    if len(text) <= max_chars:
        return text
    return text[:max_chars].rstrip() + "\n... [chunk truncated]"


def format_minified_placeholder(record: FileRecord) -> str:
    suffix = Path(record.relative_path).suffix.lower().lstrip(".") or record.language
    reason = record.minify_reason or ".aidigestminify"
    return (
        f"# {record.relative_path}\n\n"
        f"This is a minified file of type: {suffix.upper()}\n"
        f"(File exists but content excluded via {reason})\n"
    )


def record_to_section(record: FileRecord, chunk_char_limit: int) -> List[str]:
    lines = [
        f"## FILE: {record.relative_path}",
        f"- Role: {record.role}",
        f"- Mode: {record.mode}",
        f"- Language: {record.language}",
        f"- Lines: {record.line_count}",
        f"- Characters: {record.char_count}",
        "",
    ]

    if record.mode == "minified":
        lines.append("### Minified Placeholder")
        lines.extend(format_code_fence(format_minified_placeholder(record), "markdown"))
        lines.append("")
        return lines

    if record.mode == "summary":
        lines.append("### Summary")
        for point in record.summary_points:
            lines.append(f"- {point}")
        lines.append("")
        return lines

    if record.mode == "full":
        lines.append("### Full Content")
        lines.extend(format_code_fence(record.content or "", record.language))
        lines.append("")
        return lines

    lines.append("### Section Index")
    for chunk in record.chunks:
        lines.append(f"- {chunk.title} ({chunk.start_line}-{chunk.end_line})")
    lines.append("")

    for chunk in record.chunks:
        lines.append(f"### {chunk.title}")
        lines.append(f"Lines {chunk.start_line}-{chunk.end_line}")
        lines.extend(format_code_fence(cap_chunk_content(chunk.content, chunk_char_limit), record.language))
        lines.append("")

    return lines


def estimate_tokens_from_chars(char_count: int) -> int:
    return max(1, round(char_count / 4)) if char_count else 0


def build_markdown(
    root_name: str,
    records: Sequence[FileRecord],
    skipped: Sequence[Tuple[str, str]],
    max_output_chars: int,
    chunk_char_limit: int,
    stats: BuildStats,
) -> str:
    total_lines = sum(record.line_count for record in records)
    mode_counts: Dict[str, int] = {"full": 0, "chunked": 0, "summary": 0, "minified": 0}
    for record in records:
        mode_counts[record.mode] = mode_counts.get(record.mode, 0) + 1

    tree_lines = build_directory_tree(records)
    reading_guide = sorted(records, key=lambda record: (-record.priority, record.relative_path))[:12]

    out: List[str] = [
        f"# CODEBASE PACK: {root_name}",
        "",
        "## MANIFEST",
        f"- Included files: {len(records)}",
        f"- Skipped files/directories: {len(skipped)}",
        f"- Default ignored count: {stats.default_ignored_count}",
        f"- Custom ignored count: {stats.custom_ignored_count}",
        f"- Minified count: {stats.minified_count}",
        f"- Total included lines: {total_lines}",
        f"- Full files: {mode_counts.get('full', 0)}",
        f"- Chunked files: {mode_counts.get('chunked', 0)}",
        f"- Summary files: {mode_counts.get('summary', 0)}",
        f"- Minified placeholder files: {mode_counts.get('minified', 0)}",
        f"- Estimated tokens: {estimate_tokens_from_chars(stats.total_output_chars)}",
        "",
        "## READING GUIDE",
        "Start with these files first:",
    ]

    for idx, record in enumerate(reading_guide, start=1):
        out.append(f"{idx}. `{record.relative_path}` — {record.role} [{record.mode}]")

    out.extend([
        "",
        "## DIRECTORY TREE",
        *tree_lines,
        "",
        "## FILE INDEX",
        "| Path | Role | Lines | Chars | Mode |",
        "|---|---|---:|---:|---|",
    ])

    for record in records:
        out.append(
            f"| `{record.relative_path}` | {record.role} | {record.line_count} | {record.char_count} | {record.mode} |"
        )

    if skipped:
        out.extend(["", "## SKIPPED ITEMS"])
        preview = list(skipped[:120])
        for rel, reason in preview:
            out.append(f"- `{rel}` — {reason}")
        if len(skipped) > len(preview):
            out.append(f"- ... plus {len(skipped) - len(preview)} more skipped items")

    out.extend(["", "## FILE CONTENT", ""])

    current_chars = len("\n".join(out))
    truncated_sections = 0

    for idx, record in enumerate(records):
        section_lines = record_to_section(record, chunk_char_limit)
        section_text = "\n".join(section_lines)

        if current_chars + len(section_text) + 2 > max_output_chars:
            truncated_sections += 1
            if record.mode == "full":
                fallback = FileRecord(
                    relative_path=record.relative_path,
                    language=record.language,
                    role=record.role,
                    mode="summary",
                    line_count=record.line_count,
                    char_count=record.char_count,
                    priority=record.priority,
                    summary_points=record.summary_points,
                )
                section_lines = record_to_section(fallback, chunk_char_limit)
                section_text = "\n".join(section_lines)
            elif record.mode == "chunked":
                fallback = FileRecord(
                    relative_path=record.relative_path,
                    language=record.language,
                    role=record.role,
                    mode="summary",
                    line_count=record.line_count,
                    char_count=record.char_count,
                    priority=record.priority,
                    summary_points=record.summary_points,
                )
                section_lines = record_to_section(fallback, chunk_char_limit)
                section_text = "\n".join(section_lines)

        if current_chars + len(section_text) + 2 > max_output_chars:
            out.extend([
                "## OUTPUT TRUNCATION NOTICE",
                f"The output hit the max budget of {max_output_chars} characters.",
                f"Additional omitted file sections: {len(records) - idx}",
            ])
            break

        out.extend(section_lines)
        current_chars += len(section_text) + 2

    if truncated_sections:
        out.extend([
            "## BUDGET NOTES",
            f"{truncated_sections} file section(s) were automatically downgraded to summaries to stay within the output budget.",
            "",
        ])

    out.extend([
        "## HOW TO USE THIS PACK WITH AN LLM",
        "Ask the LLM to start from the manifest, reading guide, and file index, then inspect only the relevant files or chunk sections.",
        "",
    ])

    return "\n".join(out)


def build_records(
    collected: Sequence[Tuple[Path, RootConfig, str]],
    full_cutoff: int,
    chunk_cutoff: int,
    whitespace_removal: bool,
) -> Tuple[List[FileRecord], BuildStats]:
    records: List[FileRecord] = []
    stats = BuildStats(total_files=len(collected), included_count=0)

    for file_path, root_cfg, display_rel in collected:
        raw_content = read_file_content(file_path)
        if raw_content is None:
            continue

        rel_for_matching = str(file_path.relative_to(root_cfg.root)).replace("\\", "/")
        is_minified = bool(root_cfg.minify_patterns and matches_any_pattern(rel_for_matching, False, root_cfg.minify_patterns))
        content = remove_excess_whitespace(raw_content, file_path) if whitespace_removal else raw_content

        language = get_language(file_path)
        role = summarize_role(file_path)
        priority = priority_score(file_path, role)
        mode = choose_mode(file_path, role, content, priority, full_cutoff, chunk_cutoff, is_minified)
        summary_points = extract_summary_points(file_path, content, role)
        line_count = len(content.splitlines())
        char_count = len(content)
        chunks: List[Chunk] = []

        if mode == "chunked":
            if file_path.suffix.lower() in {".md", ".mdx", ".txt"}:
                chunks = chunk_markdown(content)
            else:
                chunks = chunk_code(content)

        records.append(
            FileRecord(
                relative_path=display_rel,
                language=language,
                role=role,
                mode=mode,
                line_count=line_count,
                char_count=char_count,
                priority=priority,
                content=content if mode == "full" else None,
                chunks=chunks,
                summary_points=summary_points,
                minify_reason=".aidigestminify" if is_minified else None,
                original_char_count=len(raw_content),
            )
        )

        stats.included_count += 1
        stats.total_input_chars += len(raw_content)
        stats.total_output_chars += char_count
        if is_minified:
            stats.minified_count += 1

    records.sort(key=lambda record: (-record.priority, record.relative_path))
    return records, stats


def print_output_file_stats(records: Sequence[FileRecord], mode: Optional[str]) -> None:
    if mode is None:
        return

    sortable = list(records)
    if mode == "sort":
        sortable.sort(key=lambda record: record.char_count, reverse=True)
    else:
        sortable.sort(key=lambda record: record.relative_path.lower())

    max_chars = max((record.char_count for record in sortable), default=1)
    print("\nIncluded files:")
    for record in sortable:
        bar_len = 1 if max_chars <= 0 else max(1, int((record.char_count / max_chars) * 24))
        bar = "█" * bar_len
        print(f"{record.char_count:>8} chars  {bar:<24}  {record.relative_path} [{record.mode}]")
    total_chars = sum(record.char_count for record in sortable)
    print(f"Total output chars: {total_chars}")
    print(f"Estimated tokens:  {estimate_tokens_from_chars(total_chars)}")


def build_default_output_name(roots: Sequence[Path], docs_only: bool) -> str:
    if len(roots) == 1:
        folder = roots[0].name.upper()
    else:
        folder = "MULTI"
    suffix = "DOCS" if docs_only else "CODEBASE"
    return f"STACKMD-{folder}-{suffix}.md"


def resolve_output_path(output_arg: Optional[str], roots: Sequence[Path], docs_only: bool) -> Path:
    if output_arg:
        output_path = Path(output_arg).expanduser()
        return output_path if output_path.is_absolute() else Path.cwd() / output_path

    default_name = build_default_output_name(roots, docs_only)
    if len(roots) == 1:
        return roots[0] / default_name
    return Path.cwd() / default_name


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Create a single-file markdown codebase pack for LLM review."
    )
    parser.add_argument(
        "directory",
        nargs="?",
        default=".",
        help="Directory to scan (default: current directory)",
    )
    parser.add_argument(
        "-i",
        "--input",
        nargs="+",
        help="One or more input directories. If provided, overrides the positional directory.",
    )
    parser.add_argument(
        "-o",
        "--output",
        default=None,
        help="Output path (default: STACKMD-<FOLDER>-CODEBASE.md or STACKMD-<FOLDER>-DOCS.md)",
    )
    parser.add_argument(
        "--include-hidden",
        action="store_true",
        help="Include hidden files and directories",
    )
    parser.add_argument(
        "--extensions",
        metavar="LIST",
        help="Comma-separated extensions to include, e.g. .py,.ts,.tsx,.md",
    )
    parser.add_argument(
        "--docs-only",
        action="store_true",
        help="Only include documentation files (.md and .txt)",
    )
    parser.add_argument(
        "--max-output-chars",
        type=int,
        default=1_500_000,
        help="Max characters for the final markdown output",
    )
    parser.add_argument(
        "--full-cutoff",
        type=int,
        default=12_000,
        help="Max chars for a file to usually be included in full",
    )
    parser.add_argument(
        "--chunk-cutoff",
        type=int,
        default=80_000,
        help="Max chars for a file to usually be chunked instead of summarized",
    )
    parser.add_argument(
        "--chunk-char-limit",
        type=int,
        default=18_000,
        help="Max chars per emitted chunk in chunked mode",
    )
    parser.add_argument(
        "--ignore-file",
        default=".aidigestignore",
        help="Custom ignore file name (default: .aidigestignore)",
    )
    parser.add_argument(
        "--minify-file",
        default=".aidigestminify",
        help="Custom minify file name (default: .aidigestminify)",
    )
    parser.add_argument(
        "--no-default-ignores",
        action="store_true",
        help="Disable default ignore patterns",
    )
    parser.add_argument(
        "--show-output-files",
        nargs="?",
        const="name",
        choices=("name", "sort"),
        help="Display included files with size bars; use 'sort' for largest first",
    )
    parser.add_argument(
        "--watch",
        action="store_true",
        help="Watch for changes and rebuild automatically",
    )
    parser.add_argument(
        "--watch-interval",
        type=float,
        default=1.0,
        help="Polling interval in seconds for watch mode (default: 1.0)",
    )
    parser.add_argument(
        "--whitespace-removal",
        dest="whitespace_removal",
        action="store_true",
        help="Enable whitespace removal (default behavior)",
    )
    parser.add_argument(
        "--no-whitespace-removal",
        dest="whitespace_removal",
        action="store_false",
        help="Disable whitespace removal",
    )
    parser.set_defaults(whitespace_removal=True)
    return parser.parse_args()


def resolve_roots(args: argparse.Namespace) -> List[Path]:
    raw_inputs = args.input if args.input else [args.directory]
    roots: List[Path] = []
    for raw in raw_inputs:
        path = Path(raw).expanduser().resolve()
        if not path.exists():
            raise FileNotFoundError(f"directory does not exist: {path}")
        if not path.is_dir():
            raise NotADirectoryError(f"path is not a directory: {path}")
        roots.append(path)
    return roots


def make_root_configs(roots: Sequence[Path], ignore_file: str, minify_file: str) -> List[RootConfig]:
    configs: List[RootConfig] = []
    multi = len(roots) > 1
    for root in roots:
        configs.append(
            RootConfig(
                root=root,
                display_name=root.name if multi else "",
                ignore_patterns=load_pattern_file(root, ignore_file),
                minify_patterns=load_pattern_file(root, minify_file),
            )
        )
    return configs


def compute_watch_snapshot(roots: Sequence[Path], output_path: Path) -> Dict[str, Tuple[int, int]]:
    snapshot: Dict[str, Tuple[int, int]] = {}
    for root in roots:
        for path in root.rglob("*"):
            if output_path.exists() and path.resolve() == output_path.resolve():
                continue
            try:
                stat = path.stat()
            except OSError:
                continue
            snapshot[str(path)] = (int(stat.st_mtime_ns), int(stat.st_size))
    return snapshot


def run_build(args: argparse.Namespace) -> Path:
    roots = resolve_roots(args)
    extensions = DOC_ONLY_EXTENSIONS if args.docs_only else normalize_extensions(args.extensions)
    root_cfgs = make_root_configs(roots, args.ignore_file, args.minify_file)
    collected = collect_files(
        roots=root_cfgs,
        include_hidden=args.include_hidden,
        extensions=extensions,
        use_default_ignores=not args.no_default_ignores,
    )
    records, stats = build_records(
        collected=collected.files,
        full_cutoff=args.full_cutoff,
        chunk_cutoff=args.chunk_cutoff,
        whitespace_removal=args.whitespace_removal,
    )
    stats.default_ignored_count = collected.default_ignored_count
    stats.custom_ignored_count = collected.custom_ignored_count
    stats.binary_skipped_count = collected.binary_skipped_count
    stats.skipped_count = len(collected.skipped)

    output_path = resolve_output_path(args.output, roots, args.docs_only)
    root_name = roots[0].name if len(roots) == 1 else "MULTI"
    markdown = build_markdown(
        root_name=root_name,
        records=records,
        skipped=collected.skipped,
        max_output_chars=args.max_output_chars,
        chunk_char_limit=args.chunk_char_limit,
        stats=stats,
    )

    output_path.parent.mkdir(parents=True, exist_ok=True)
    output_path.write_text(markdown, encoding="utf-8")

    total_lines = sum(record.line_count for record in records)
    print(
        f"Created {output_path} with {len(records)} included files, "
        f"{len(collected.skipped)} skipped items, {stats.minified_count} minified files, "
        f"and {total_lines} included lines"
    )
    if args.show_output_files:
        print_output_file_stats(records, args.show_output_files)
    return output_path


def watch_and_rebuild(args: argparse.Namespace) -> int:
    roots = resolve_roots(args)
    output_path = resolve_output_path(args.output, roots, args.docs_only)
    last_snapshot: Optional[Dict[str, Tuple[int, int]]] = None

    try:
        while True:
            try:
                current_snapshot = compute_watch_snapshot(roots, output_path)
                if last_snapshot is None or current_snapshot != last_snapshot:
                    run_build(args)
                    last_snapshot = current_snapshot
                time.sleep(max(0.2, args.watch_interval))
            except KeyboardInterrupt:
                print("\nWatch mode stopped.")
                return 0
    except KeyboardInterrupt:
        print("\nWatch mode stopped.")
        return 0


def main() -> int:
    args = parse_args()
    try:
        if args.watch:
            return watch_and_rebuild(args)
        run_build(args)
        return 0
    except FileNotFoundError as exc:
        eprint(f"Error: {exc}")
        return 1
    except NotADirectoryError as exc:
        eprint(f"Error: {exc}")
        return 1


if __name__ == "__main__":
    sys.exit(main())

